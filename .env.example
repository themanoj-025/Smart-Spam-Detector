# ============================================================
# Spam Email Classifier — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you need.

# API Key for FastAPI authentication (optional)
# When set, all /predict endpoints require: Authorization: Bearer <key>
# SPAM_API_KEY=your-secret-api-key-here

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Streamlit theme (configured in .streamlit/config.toml)
# STREAMLIT_THEME=light
