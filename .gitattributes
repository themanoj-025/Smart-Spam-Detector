# Auto-detect text files and normalize line endings
* text=auto

# Python source
*.py text diff=python

# Jupyter notebooks
*.ipynb text diff=jupyter

# HTML templates
*.html text diff=html

# CSS stylesheets
*.css text

# JavaScript
*.js text

# Markdown documentation
*.md text
*.rst text

# Config files
*.yml text
*.yaml text
*.toml text
*.json text
*.cfg text
*.ini text
*.env text

# Shell / batch scripts
*.sh text eol=lf
*.bat text eol=crlf

# Docker
Dockerfile text
Dockerfile.* text

# Requirements
requirements.txt text
requirements-dev.txt text
runtime.txt text
packages.txt text

# Project config
pyproject.toml text
LICENSE text

# Binary / ML model files - don't modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pkl binary
*.pickle binary
*.joblib binary
*.npy binary
*.npz binary
*.db binary
*.sqlite binary
*.zip binary
